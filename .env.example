PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3010
NEXT_PUBLIC_APP_URL=http://localhost:${PORT}

# Posthog product analytics (opcional — si no se setea, el cliente NO se inicializa
# y todas las llamadas a `analytics.*` son no-op silenciosas. Ver
# docs/business/growth-roadmap.md#stack-de-analytics para la taxonomía completa).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Playwright E2E (solo desarrollo — NUNCA producción)
# Debe coincidir con el TEST_AUTH_SECRET configurado en el backend (mínimo 32 chars).
E2E_BASE_URL=http://localhost:3000
E2E_API_URL=http://localhost:3010
TEST_AUTH_SECRET=
